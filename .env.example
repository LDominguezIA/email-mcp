# ═══════════════════════════════════════════════════════════════
# email-mcp — Configuración de credenciales
# Copia este archivo como .env y rellena UNA de las dos opciones.
# El servidor detecta automáticamente el modo al arrancar.
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# OPCIÓN A: SMTP — Solo necesitas tu email y contraseña de Outlook
# Funciona con: Microsoft 365 corporativo y Outlook.com personal
# ──────────────────────────────────────────────────────────────

SMTP_USER=ldominguez@atisa.com
SMTP_PASS=tu_contraseña_de_outlook

# Si tienes MFA (autenticación de dos factores) activa, necesitas
# una contraseña de aplicación en lugar de tu contraseña normal:
# → https://account.microsoft.com/security > Opciones de seguridad avanzadas > Contraseñas de aplicación

# Servidor SMTP (no cambiar salvo casos especiales)
# SMTP_HOST=smtp.office365.com   ← Microsoft 365 corporativo (default)
# SMTP_HOST=smtp-mail.outlook.com ← Outlook.com personal
# SMTP_PORT=587

# Limitaciones del modo SMTP vs Graph API:
#   ✅ Enviar emails inmediatamente
#   ✅ Programar y cancelar envíos
#   ✅ Renderizar y enviar plantillas HTML
#   ❌ Crear borradores (requiere Graph API)
#   ❌ Consultar enviados (requiere Graph API)

FROM_EMAIL=ldominguez@atisa.com


# ──────────────────────────────────────────────────────────────
# OPCIÓN B: Microsoft Graph API — Funcionalidad completa
# Requiere un App Registration en Azure Active Directory
# → portal.azure.com > Azure AD > App registrations
# Permisos necesarios: Mail.Send + Mail.ReadWrite (Application)
# ──────────────────────────────────────────────────────────────

# TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CLIENT_SECRET=tu_client_secret_aqui
# FROM_EMAIL=ldominguez@atisa.com
